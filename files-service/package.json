    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "express": "^5.2.1",
    "formidable": "^3.5.4",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  }
