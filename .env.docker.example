# .env.docker.example = versionné
# .env.docker         = non versionné

# Ce fichier regroupe les variables d'environnement à fournir au docker-compose pour le lancement des différents services

# Local : 
#        docker compose --env-file=.env.docker.example
# (ou)   docker compose --env-file=.env.docker

# Prod :  
#        docker compose --env-file=.env.docker


# DATABASE
POSTGRES_USER=oquiz
POSTGRES_PASSWORD=oquiz
POSTGRES_DB=oquiz
POSTGRES_LOCAL_PORT=5454

# API
NODE_ENV=production
DATABASE_URL=postgres://oquiz:oquiz@database:5432/oquiz
API_LOCAL_PORT=3001
JWT_SECRET=mon-super-secret-jwt
ALLOWED_ORIGINS=oquiz.PSEUDO-server.eddi.cloud
LOG_LEVEL=http

# LOGS SERVICE
LOGS_DATABASE_URL=mongodb://logs-db:27017/log_service
LOGS_SERVICE_LOCAL_PORT=3500
LOGS_DB_LOCAL_PORT=27017

# CLIENT
VITE_API_BASE_URL=http://oquiz-api.PSEUDO-server.eddi.cloud/api
CLIENT_LOCAL_PORT=8000

# ADMINER
ADMINER_LOCAL_PORT=8080

# PROXY
PROXY_LOCAL_PORT=4000
CLIENT_SERVER_NAME=oquiz.PSEUDO-server.eddi.cloud
API_SERVER_NAME=oquiz-api.PSEUDO-server.eddi.cloud
