datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

model User {
  id Int @id @default(autoincrement())

  firstname String
  lastname  String
  email     String @unique()
  password  String

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("user") // Correspondance entre le model User dans le code et la table "user" dans la BDD
}

model Level {
  id Int @id @default(autoincrement())

  name String @unique()

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@map("level")
}
